{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-snip@latest",
    "cc-safety-net",
    "@slkiser/opencode-quota",
    "opencode-pty"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    },
    "youtube-transcript": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@thecat69/youtube-transcript-mcp"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN={env:GITHUB_TOKEN}",
        "-e",
        "GITHUB_TOOLSETS=repos,code_security,dependabot,security_advisories,actions",
        "-e",
        "GITHUB_READ_ONLY=true",
        "ghcr.io/github/github-mcp-server"
      ],
      "enabled": true
    }
  },
  "permission": {
    "context7_*": "deny",
    "youtube-transcript_*": "deny",
    "github_*": "deny"
  },
  "agent": {
    "build": {
      "permission": {
        "context7_*": "allow",
        "youtube-transcript_*": "allow",
        "github_*": "allow"
      }
    },
    "plan": {
      "permission": {
        "context7_*": "allow",
        "youtube-transcript_*": "allow",
        "github_*": "allow"
      }
    }
  },
  "lsp": {
    "jdtls": {
      "disabled": true
    },
    "jdtls-lombok": {
      "command": [
        "{env:HOME}/.local/share/opencode/bin/jdtls/bin/jdtls",
        "--jvm-arg=-javaagent:{env:HOME}/dev-tools/jars/lombok.jar",
        "-configuration",
        "{env:HOME}/.local/share/opencode/bin/jdtls/config_linux",
        "-data",
        "/tmp/opencode-jdtls-data"
      ],
      "extensions": [
        ".java"
      ]
    }
  }
}
