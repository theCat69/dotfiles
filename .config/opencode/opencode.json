{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@slkiser/opencode-quota",
    "@mohak34/opencode-notifier@latest"
  ],
  "mcp": {
    "youtube-transcript": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@thecat69/youtube-transcript-mcp"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN={env:GITHUB_TOKEN}",
        "-e",
        "GITHUB_TOOLSETS=repos,code_security,dependabot,security_advisories,actions",
        "-e",
        "GITHUB_READ_ONLY=true",
        "ghcr.io/github/github-mcp-server"
      ],
      "enabled": true
    },
    "azure-devops": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@azure-devops/mcp",
        "gca-trans"
      ],
      "enabled": true
    }
  },
  "permission": {
    "context7_*": "deny",
    "youtube-transcript_*": "deny",
    "github_*": "deny",
    "azure-devops_*": "deny"
  },
  "agent": {
    "build": {
      "permission": {
        "context7_*": "allow",
        "youtube-transcript_*": "allow",
        "github_*": "allow"
      }
    },
    "plan": {
      "permission": {
        "context7_*": "allow",
        "youtube-transcript_*": "allow",
        "github_*": "allow"
      }
    }
  },
  "lsp": {
    "jdtls": {
      "disabled": true
    },
    "jdtls-lombok": {
      "command": [
        "{env:HOME}/.local/share/opencode/bin/jdtls/bin/jdtls",
        "--jvm-arg=-javaagent:{env:HOME}/dev-tools/jars/lombok.jar",
        "-configuration",
        "{env:HOME}/.local/share/opencode/bin/jdtls/config_linux",
        "-data",
        "/tmp/opencode-jdtls-data"
      ],
      "extensions": [
        ".java"
      ]
    }
  },
  "provider": {
    "azure_foundry": {
      "name": "azure_foundry",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://poc-copilot.services.ai.azure.com/openai/v1",
        "apiKey": "{env:AZURE_FOUNDRY_API_KEY}",
        "headers": {
          "api-key": "{env:AZURE_FOUNDRY_API_KEY}"
        }
      },
      "models": {
        "DeepSeek-V4-Flash": {
          "name": "DeepSeek-V4-Flash"
        },
        "Kimi-K2.6": {
          "name": "Kimi-K2.6"
        },
        "gpt-5.4": {
          "name": "gpt-5.4",
          "reasoning": true,
          "provider": {
            "npm": "@ai-sdk/openai"
          }
        },
        "gpt-5.3-codex": {
          "name": "gpt-5.3-codex",
          "reasoning": true,
          "provider": {
            "npm": "@ai-sdk/openai"
          }
        },
        "gpt-5.4-nano": {
          "name": "gpt-5.4-nano",
          "provider": {
            "npm": "@ai-sdk/openai"
          }
        }
      }
    },
    "azure_foundry_suede": {
      "name": "azure_foundry_suede",
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "https://frede-mjjufhbm-swedencentral.openai.azure.com/openai/v1",
        "apiKey": "{env:AZURE_API_KEY_SUEDE}",
        "headers": {
          "api-key": "{env:AZURE_API_KEY_SUEDE}"
        }
      },
      "models": {
        "gpt-5.4-pro": {
          "name": "gpt-5.4-pro"
        }
      }
    }
  }
}
